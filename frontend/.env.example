VITE_API_BASE=/api
VITE_GAS_STATION_URL=/gas
VITE_SUI_NETWORK=testnet

# Current package for VITE_SUI_NETWORK.
VITE_PKG_ID=

# Shared objects required by sponsored intel attestations.
VITE_SCHEMA_REGISTRY_ID=
VITE_SCHEMA_REGISTRY_VERSION=
VITE_ORACLE_REGISTRY_ID=
VITE_ORACLE_REGISTRY_VERSION=

# Smart Gate policy write flow.
# Gate policy is the shared reputation_gate::GatePolicy object.
# Admin cap is the owned reputation_gate::GateAdminCap object held by the EVE Vault wallet.
VITE_GATE_POLICY_ID=
VITE_GATE_POLICY_VERSION=
VITE_GATE_ADMIN_CAP_ID=
VITE_GATE_ADMIN_OWNER=

# EVE Vault wallet — primary game wallet for all on-chain operations.
# Operates with EVT (in-game currency) and SUI.
VITE_ORACLE_ADDRESS=
