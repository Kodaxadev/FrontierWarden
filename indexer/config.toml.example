[network]
rpc_url = "https://fullnode.testnet.sui.io:443"

[package]
# Canonical deployed package — do NOT re-publish; this address is the source of truth.
id = "0x5a2c11eecb782820e2247d11103427cf19ea3c61f4aea00c0a330add597f6c13"

# First checkpoint to index. 0 = from genesis. The deploy checkpoint was 349181586;
# set it here to skip pre-deploy history. Ignored if a cursor is already persisted.
start_checkpoint = 349181586

[database]
# Set EFREP_DATABASE_URL in the environment; never commit live credentials.
url             = "env:EFREP_DATABASE_URL"
max_connections = 5

[indexer]
# Events fetched per RPC call. Sui fullnode caps at 1000.
batch_size       = 100
# Milliseconds to sleep when no new events are available.
poll_interval_ms = 1000

[sponsor]
# Gas station sponsor keypair (suiprivkey1... format).
# Required to sign sponsored transactions. Set via env var: SPONSOR_KEYPAIR=...
# or in this config. If both are set, env var takes precedence.
# WARNING: Never commit this to version control. Use .gitignore and env vars in production.
keypair = ""

# Rate limit for sponsor requests (requests per second).
# Set to 0 for unlimited (not recommended for production).
# Default: 10 req/s
rate_limit = 10
